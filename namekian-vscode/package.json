{
  "name": "namekian-vscode",
  "displayName": "Namekian",
  "description": "Language support for Namekian (.nk files)",
  "version": "0.1.0",
  "publisher": "namekian",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/namekian/namekian"
  },
  "license": "MIT",
  "keywords": [
    "namekian",
    "nk",
    "programming language",
    "transpiler"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:namekian"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "namekian",
        "aliases": [
          "Namekian",
          "nk"
        ],
        "extensions": [
          ".nk"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "namekian",
        "scopeName": "source.namekian",
        "path": "./syntaxes/namekian.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --watch",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  }
}
