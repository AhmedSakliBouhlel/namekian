{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Namekian",
  "scopeName": "source.namekian",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#string-interpolation" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#function-declaration" },
    { "include": "#function-call" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.namekian",
          "match": "//.*$"
        },
        {
          "name": "comment.block.namekian",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.namekian",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.namekian",
              "match": "\\\\."
            },
            {
              "name": "meta.embedded.expression.namekian",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.begin.namekian"
                }
              },
              "endCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.end.namekian"
                }
              },
              "patterns": [{ "include": "source.namekian" }]
            }
          ]
        },
        {
          "name": "string.quoted.single.namekian",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.namekian",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "string-interpolation": {
      "patterns": [
        {
          "name": "meta.template.expression.namekian",
          "begin": "\\$\\{",
          "end": "\\}",
          "patterns": [{ "include": "source.namekian" }]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.namekian",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.namekian",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.namekian",
          "match": "\\b(if|else|for|while|return|match|break|continue|in|try|catch)\\b"
        },
        {
          "name": "keyword.other.namekian",
          "match": "\\b(take|from|load|new|this)\\b"
        },
        {
          "name": "keyword.declaration.namekian",
          "match": "\\b(var|struct|class|interface|enum|type)\\b"
        },
        {
          "name": "keyword.operator.result.namekian",
          "match": "\\b(Ok|Err|Result)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.namekian",
          "match": "\\b(int|float|string|bool|void)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.namekian",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.namekian",
          "match": "\\bnull\\b"
        }
      ]
    },
    "function-declaration": {
      "patterns": [
        {
          "comment": "Function declaration: returnType name(...) or name<T>(...)",
          "match": "\\b([a-zA-Z_]\\w*)\\s*(?=<[^>]*>\\s*\\(|\\()",
          "captures": {
            "1": { "name": "entity.name.function.namekian" }
          }
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "comment": "Method or function call: name(",
          "match": "\\b([a-zA-Z_]\\w*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.namekian" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.namekian",
          "match": "=>"
        },
        {
          "name": "keyword.operator.spread.namekian",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.comparison.namekian",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.namekian",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.compound.namekian",
          "match": "\\+=|-=|\\*=|/=|%="
        },
        {
          "name": "keyword.operator.assignment.namekian",
          "match": "="
        },
        {
          "name": "keyword.operator.increment-decrement.namekian",
          "match": "\\+\\+|--"
        },
        {
          "name": "keyword.operator.arithmetic.namekian",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.ternary.namekian",
          "match": "\\?|:"
        },
        {
          "name": "keyword.operator.optional-chaining.namekian",
          "match": "\\?\\."
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.namekian",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.namekian",
          "match": ","
        },
        {
          "name": "punctuation.accessor.namekian",
          "match": "\\."
        }
      ]
    }
  }
}
